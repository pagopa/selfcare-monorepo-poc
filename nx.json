{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/.eslintrc.json"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "deploy": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "build": {
      "cache": true
    },
    "nx-release-publish": {
      "dependsOn": [
        "build",
        "^nx-release-publish"
      ]
    }
  },
  "release": {
    "versionPlans": true,
    "projectsRelationship": "independent",
    "projects": [
      "apps/**"
    ],
    "docker": {
      "registryUrl": "ghcr.io",
      "versionSchemes": {
        "production": "{versionActionsVersion}"
      },
      "groupPreVersionCommand": "echo Building docker images before publish && pnpm nx affected -t docker:build"
    },
    "version": {},
    "changelog": {
      "projectChangelogs": {
        "createRelease": false,
        "file": "{projectRoot}/CHANGELOG.md",
        "renderOptions": {
          "authors": true,
          "applyUsernameToAuthors": true,
          "commitReferences": true,
          "versionTitleDate": false
        }
      }
    },
    "git": {
      "commit": false,
      "tag": true,
      "stageChanges": false
    },
    "releaseTag": {
      "pattern": "{projectName}@{version}",
      "requireSemver": true,
      "preferDockerVersion": true,
      "strictPreid": false
    }
  },
  "plugins": [
    {
      "plugin": "@nx/docker",
      "exclude": [],
      "options": {
        "buildTarget": {
          "name": "docker:build",
          "args": [
            "--platform linux/arm64,linux/amd64",
            "--label org.opencontainers.image.title={projectName}",
            "--label org.opencontainers.image.description=\"$(desc=$(grep -m1 '\"description\"' package.json | cut -d '\"' -f4); if [ -n \"$desc\" ]; then printf '%s' \"$desc\"; else grep -m1 '\"name\"' package.json | cut -d '\"' -f4; fi)\"",
            "--label org.opencontainers.image.source=https://github.com/pagopa/selfcare-monorepo-poc",
            "--label org.opencontainers.image.url=https://github.com/pagopa/selfcare-monorepo-poc",
            "--label org.opencontainers.image.revision={commitSha}",
            "--label org.opencontainers.image.created={currentDate}",
            "--provenance=false"
          ],
          "env": {
            "DOCKER_BUILDKIT": "1"
          }
        }
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json",
          "buildDepsName": "build-deps",
          "watchDepsName": "watch-deps"
        }
      }
    }
  ],
  "analytics": false
}
