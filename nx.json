{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/.eslintrc.json"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "deploy": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "build": {
      "cache": true
    },
    "docker:build": {
      "options": {
        "provenance": "false",
        "tags": [
          "ghcr.io/pagopa/dx-slc-{projectName}:dev"
        ]
      },
      "configurations": {
        "ci": {
          "platforms": [
            "linux/arm64",
            "linux/amd64"
          ],
          "metadata": {
            "images": [
              "ghcr.io/pagopa/dx-slc-{projectName}"
            ],
            "tags": [
              "type=raw,value=latest,enable={{is_default_branch}}",
              "type=match,pattern=.*@(\\d+\\.\\d+\\.\\d+)$,group=1",
              "type=match,pattern=.*@(\\d+\\.\\d+)\\.\\d+$,group=1",
              "type=match,pattern=.*@([1-9]\\d*)\\.\\d+\\.\\d+$,group=1",
              "type=ref,event=branch",
              "type=sha,prefix=sha-"
            ]
          }
        }
      }
    },
    "docker:run": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "docker:build"
      ],
      "options": {
        "cwd": "{projectRoot}",
        "command": "docker run {args} ghcr.io/pagopa/dx-slc-{projectName}:dev"
      }
    },
    "nx-release-publish": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": [
        "build",
        "^nx-release-publish"
      ],
      "options": {
        "load": false,
        "platforms": [
          "linux/arm64",
          "linux/amd64"
        ],
        "provenance": "false",
        "push": true,
        "metadata": {
          "images": [
            "ghcr.io/pagopa/dx-slc-{projectName}"
          ],
          "tags": [
            "type=raw,value=latest,enable={{is_default_branch}}",
            "type=match,pattern=.*@(\\d+\\.\\d+\\.\\d+)$,group=1",
            "type=match,pattern=.*@(\\d+\\.\\d+)\\.\\d+$,group=1",
            "type=match,pattern=.*@([1-9]\\d*)\\.\\d+\\.\\d+$,group=1",
            "type=ref,event=branch",
            "type=sha,prefix=sha-"
          ]
        }
      }
    }
  },
  "release": {
    "versionPlans": true,
    "projectsRelationship": "independent",
    "projects": [
      "apps/**"
    ],
    "docker": {
      "registryUrl": "ghcr.io",
      "versionSchemes": {
        "production": "{versionActionsVersion}"
      },
      "preVersionCommand": "echo Building docker images before publish && pnpm nx affected -t docker:build"
    },
    "version": {},
    "changelog": {
      "projectChangelogs": {
        "createRelease": false,
        "file": "{projectRoot}/CHANGELOG.md",
        "renderOptions": {
          "authors": true,
          "applyUsernameToAuthors": true,
          "commitReferences": true,
          "versionTitleDate": false
        }
      }
    },
    "git": {
      "commit": false,
      "tag": true,
      "stageChanges": false
    },
    "releaseTag": {
      "pattern": "{projectName}@{version}",
      "requireSemver": true,
      "preferDockerVersion": true,
      "strictPreid": false
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json",
          "buildDepsName": "build-deps",
          "watchDepsName": "watch-deps"
        }
      }
    },
    {
      "plugin": "@nx-tools/nx-container",
      "options": {
        "defaultEngine": "docker",
        "defaultRegistry": "ghcr.io",
        "buildTargetName": "docker:build"
      }
    }
  ],
  "analytics": false
}
